---
import MainLayout from '../layouts/MainLayout.astro';
import { getEntry } from 'astro:content';

const aboutPage = await getEntry('pages', 'about');
const { 
	title, 
	missionTitle, 
	missionDescription, 
	aboutTitle, 
	aboutDescription, 
	valuesTitle, 
	values, 
	teachersTitle,
	teachers,
	ctaTitle, 
	ctaDescription 
} = aboutPage.data;
---

<MainLayout title={title}>
	<section class="py-24">
		<div class="container mx-auto px-4">
			<div class="max-w-4xl mx-auto space-y-24">
				
				<!-- Mission -->
				<div class="text-center space-y-6">
					<h1 class="text-4xl md:text-7xl font-cairo font-black tracking-tight text-gradient">
						{missionTitle}
					</h1>
					<p class="text-xl md:text-2xl text-muted-foreground max-w-2xl mx-auto font-bold leading-relaxed">
						{missionDescription}
					</p>
				</div>
				
				<!-- Hero Image -->
				<div class="overflow-hidden rounded-[3rem] shadow-2xl relative aspect-[21/9] border-8 border-card">
					<img 
						src="https://images.unsplash.com/photo-1524178232363-1fb2b075b655?auto=format&fit=crop&q=80&w=1200" 
						alt="عن أكاديمية KSA" 
						class="w-full h-full object-cover"
						loading="lazy"
					/>
					<div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent flex items-end p-8 md:p-16">
						<p class="text-white text-2xl md:text-4xl font-cairo font-black max-w-2xl leading-tight">
							نحن نؤمن بأن التعليم عالي الجودة هو حق لكل طالب طموح.
						</p>
					</div>
				</div>

				<!-- About & Values -->
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
					<div class="space-y-8">
						<h2 class="text-4xl font-cairo font-black tracking-tight">{aboutTitle}</h2>
						<div class="prose prose-xl dark:prose-invert font-cairo text-muted-foreground font-bold leading-loose">
							<p>{aboutDescription}</p>
						</div>
					</div>
					<div class="bg-primary/5 rounded-[3rem] p-8 md:p-12 border-2 border-primary/10 shadow-inner">
						<h3 class="text-3xl font-cairo font-black mb-8">{valuesTitle}</h3>
						<ul class="space-y-6">
							{values.map((value) => (
								<li class="flex items-center gap-4">
									<div class="w-10 h-10 rounded-2xl bg-primary/20 text-primary flex items-center justify-center shrink-0">
										<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
									</div>
									<span class="text-lg font-black font-cairo">{value}</span>
								</li>
							))}
						</ul>
					</div>
				</div>

				<!-- Teachers Section -->
				{teachers && (
					<div class="space-y-12">
						<div class="text-center">
							<h2 class="text-4xl font-cairo font-black tracking-tight">{teachersTitle}</h2>
						</div>
						<div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
							{teachers.map(teacher => (
								<div class="text-center p-8 rounded-[2rem] bg-card border-2 border-primary/5 hover:border-primary/20 transition-all group reveal">
									<div class="w-16 h-16 rounded-2xl bg-primary/10 text-primary flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform">
										<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
									</div>
									<h4 class="text-xl font-black font-cairo">{teacher.name}</h4>
									<p class="text-primary font-bold text-sm mt-2">{teacher.role}</p>
								</div>
							))}
						</div>
					</div>
				)}

				<!-- CTA -->
				<div class="text-center bg-zinc-950 rounded-[4rem] py-20 px-8 space-y-10 shadow-2xl relative overflow-hidden reveal border-8 border-white/5">
					<div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-primary/20 blur-[100px]"></div>
					<div class="absolute -left-20 -bottom-20 h-64 w-64 rounded-full bg-secondary/20 blur-[100px]"></div>
					
					<h2 class="text-4xl md:text-6xl font-cairo font-black text-white relative z-10 leading-tight">{ctaTitle}</h2>
					<p class="text-xl md:text-2xl text-zinc-400 max-w-2xl mx-auto relative z-10 font-bold">{ctaDescription}</p>
					
					<div class="relative z-10 flex flex-wrap justify-center gap-6">
						<a 
							href="/blog" 
							class="h-16 px-12 inline-flex items-center justify-center rounded-full bg-white text-zinc-950 text-xl font-black transition-all hover:scale-105 shadow-xl"
						>
							تصفح الكورسات
						</a>
						<a 
							href="/contact" 
							class="h-16 px-12 inline-flex items-center justify-center rounded-full border-2 border-white/20 text-white text-xl font-black transition-all hover:bg-white/10"
						>
							اتصل بنا
						</a>
					</div>
				</div>

			</div>
		</div>
	</section>
</MainLayout>
