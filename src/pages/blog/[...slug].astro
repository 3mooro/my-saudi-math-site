---
import MainLayout from '../../layouts/MainLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { env } from 'cloudflare:workers';
import { marked } from 'marked';

const { slug } = Astro.params;
const db = env.DB;

let postRaw;
try {
  postRaw = await db.prepare("SELECT * FROM blog WHERE slug = ?").bind(slug).first();
} catch (e) {
  console.error("D1 Fetch Error:", e);
}

if (!postRaw) {
  return Astro.redirect('/404');
}

const title = postRaw.title;
const description = postRaw.description;
const pubDate = new Date(postRaw.pubDate);
const heroImage = postRaw.heroImage;
const author = postRaw.author;
const readingTime = postRaw.readingTime;
const tags = postRaw.tags ? JSON.parse(postRaw.tags) : [];
const contentHtml = marked.parse(postRaw.body || '');
---

<MainLayout title={`${title} | أكاديمية KSA`} description={description}>
	<article class="py-12 md:py-24">
		<div class="container mx-auto px-4 max-w-4xl">
			<div class="space-y-8 mb-12 text-center reveal">
				{tags && tags.length > 0 && (
					<div class="flex justify-center gap-2 mb-4">
						{tags.map((tag: string) => (
							<span class="px-4 py-1 bg-primary/10 text-primary text-sm font-black rounded-full font-cairo">
								{tag}
							</span>
						))}
					</div>
				)}
				
				<h1 class="text-4xl md:text-6xl font-cairo font-black tracking-tight leading-tight">
					{title}
				</h1>
				
				<div class="flex items-center justify-center gap-6 text-muted-foreground font-bold">
					<div class="flex items-center gap-2">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
						<FormattedDate date={pubDate} />
					</div>
					<div class="flex items-center gap-2">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
						<span>{readingTime}</span>
					</div>
					<div class="flex items-center gap-2">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
						<span>{author}</span>
					</div>
				</div>
			</div>

			{heroImage && (
				<div class="aspect-video rounded-[3rem] overflow-hidden shadow-2xl mb-16 border-8 border-card reveal">
					<img 
						src={heroImage} 
						alt={title}
						class="w-full h-full object-cover"
					/>
				</div>
			)}

			<div class="prose prose-xl dark:prose-invert max-w-none font-cairo leading-loose text-justify text-muted-foreground font-bold article-content reveal">
				<div set:html={contentHtml} />
			</div>
			
			<!-- Share & CTA -->
			<div class="mt-16 pt-8 border-t-2 border-primary/5 flex flex-col md:flex-row justify-between items-center gap-8 reveal">
				<div class="flex items-center gap-4">
					<span class="font-black text-foreground font-cairo">مشاركة المقال:</span>
					<!-- Share buttons (simplified for example) -->
					<div class="flex gap-2">
						<button class="w-12 h-12 rounded-full bg-primary/10 text-primary flex items-center justify-center hover:bg-primary hover:text-white transition-colors">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
						</button>
						<button class="w-12 h-12 rounded-full bg-primary/10 text-primary flex items-center justify-center hover:bg-primary hover:text-white transition-colors">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
						</button>
					</div>
				</div>
				
				<a href="/#courses" class="px-8 py-4 bg-primary text-white rounded-full font-black font-cairo shadow-lg shadow-primary/20 hover:-translate-y-1 transition-transform">
					تصفح باقاتنا التعليمية
				</a>
			</div>
		</div>
	</article>
</MainLayout>

<style is:global>
	/* Custom styles for rendered markdown content */
	.article-content h2 {
		font-size: 1.875rem;
		line-height: 2.25rem;
		font-weight: 900;
		color: var(--foreground);
		margin-top: 3rem;
		margin-bottom: 1.5rem;
	}
	.article-content h3 {
		font-size: 1.5rem;
		line-height: 2rem;
		font-weight: 900;
		color: var(--foreground);
		margin-top: 2rem;
		margin-bottom: 1rem;
	}
	.article-content p {
		margin-bottom: 1.5rem;
	}
	.article-content ul {
		list-style-type: disc;
		list-style-position: inside;
		margin-bottom: 1.5rem;
		padding-right: 1.5rem;
	}
	.article-content ul li {
		margin-bottom: 0.5rem;
	}
	.article-content blockquote {
		border-right-width: 4px;
		border-left-width: 0;
		border-color: var(--primary);
		padding-left: 0;
		padding-right: 1.5rem;
		font-style: italic;
		background-color: rgba(var(--primary-rgb), 0.05);
		padding-top: 1rem;
		padding-bottom: 1rem;
		border-top-left-radius: 1rem;
		border-bottom-left-radius: 1rem;
	}
</style>
