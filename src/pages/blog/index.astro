---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { Image } from 'astro:assets';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<MainLayout title="Our Courses | KSA Academy">
	<section class="py-24">
		<div class="container mx-auto px-4">
			<div class="max-w-3xl mb-16 space-y-4">
				<h1 class="text-4xl md:text-6xl font-poppins font-bold tracking-tight text-gradient">
					Our Courses & Resources
				</h1>
				<p class="text-xl text-muted-foreground">
					Explore our collection of expert-led courses and educational materials designed to help you excel in your studies.
				</p>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-2 gap-12">
				{posts.map((post, index) => (
					<article class:list={[
						"group relative flex flex-col space-y-4",
						index === 0 ? "md:col-span-2 md:flex-row md:space-y-0 md:space-x-12 items-center" : ""
					]}>
						{post.data.heroImage && (
							<a href={`/blog/${post.id}/`} class:list={[
								"overflow-hidden rounded-3xl shadow-lg transition-all group-hover:shadow-2xl group-hover:-translate-y-1",
								index === 0 ? "md:w-1/2 aspect-[16/9]" : "aspect-video"
							]}>
								<Image 
									width={720} 
									height={360} 
									src={post.data.heroImage} 
									alt="" 
									class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
								/>
							</a>
						)}
						<div class:list={[
							"space-y-3",
							index === 0 ? "md:w-1/2" : ""
						]}>
							<div class="text-sm font-medium text-muted-foreground">
								<FormattedDate date={post.data.pubDate} />
							</div>
							<a href={`/blog/${post.id}/`}>
								<h2 class:list={[
									"font-poppins font-bold tracking-tight transition-colors group-hover:text-primary",
									index === 0 ? "text-3xl md:text-5xl" : "text-2xl md:text-3xl"
								]}>
									{post.data.title}
								</h2>
							</a>
							<p class="text-muted-foreground line-clamp-2 md:line-clamp-3 leading-relaxed">
								{post.data.description}
							</p>
							<a 
								href={`/blog/${post.id}/`} 
								class="inline-flex items-center gap-2 font-bold text-primary hover:underline group/link"
							>
								Read More
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover/link:translate-x-1"><line x1="5" x2="19" y1="12" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
							</a>
						</div>
					</article>
				))}
			</div>
		</div>
	</section>
</MainLayout>
