---
import MainLayout from '../layouts/MainLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { WHATSAPP_NUMBER, TWITTER_LINK, INSTAGRAM_LINK, LINKEDIN_LINK } from '../consts';
---

<MainLayout title="اتصل بنا | أكاديمية KSA" description="تواصل معنا للاستفسار عن الدورات والمراجعات النهائية. نحن هنا لدعم تفوقك الدراسي في أي وقت.">
	<section class="py-24 relative overflow-hidden">
		<!-- Background decorations -->
		<div class="absolute top-0 left-0 w-full h-full -z-10 opacity-5">
			<div class="absolute top-20 left-10 w-64 h-64 bg-primary rounded-full blur-3xl"></div>
			<div class="absolute bottom-20 right-10 w-64 h-64 bg-secondary rounded-full blur-3xl"></div>
		</div>

		<div class="container mx-auto px-4">
			<Breadcrumbs items={[{ label: 'اتصل بنا' }]} />

			<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
				
				<div class="space-y-8">
					<div class="space-y-4">
						<h1 class="text-4xl md:text-6xl font-cairo font-black tracking-tight text-gradient">تواصل معنا</h1>
						<p class="text-xl text-muted-foreground font-bold leading-relaxed">
							هل لديك استفسار عن كورساتنا؟ أو تحتاج لمساعدة في حجز موعد؟ نحن هنا للإجابة على جميع تساؤلاتك.
						</p>
					</div>

					<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
						<a href={`https://wa.me/${WHATSAPP_NUMBER}`} target="_blank" class="p-8 rounded-[2rem] bg-card border hover:border-primary/30 transition-all group shadow-sm hover:shadow-xl">
							<div class="w-14 h-14 rounded-2xl bg-primary/10 text-primary flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
								<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.79 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
							</div>
							<h3 class="text-xl font-black mb-2">واتساب مباشر</h3>
							<p class="text-muted-foreground font-bold text-sm">تواصل معنا فوراً لحجز حصتك.</p>
						</a>

						<div class="p-8 rounded-[2rem] bg-card border shadow-sm">
							<div class="w-14 h-14 rounded-2xl bg-secondary/10 text-secondary flex items-center justify-center mb-6">
								<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
							</div>
							<h3 class="text-xl font-black mb-2">البريد الإلكتروني</h3>
							<p class="text-muted-foreground font-bold text-sm">support@ksaacademy.online</p>
						</div>
					</div>

					<div class="p-8 rounded-[2.5rem] bg-zinc-950 text-white shadow-2xl relative overflow-hidden">
						<div class="absolute -right-10 -bottom-10 w-40 h-40 bg-primary/20 rounded-full blur-3xl"></div>
						<h3 class="text-2xl font-black mb-6 relative z-10">تابعنا على المنصات الأخرى</h3>
						<div class="flex gap-4 relative z-10">
							<a href={TWITTER_LINK} class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center hover:bg-primary transition-colors">
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path></svg>
							</a>
							<a href={INSTAGRAM_LINK} class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center hover:bg-primary transition-colors">
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>
							</a>
							<a href={LINKEDIN_LINK} class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center hover:bg-primary transition-colors">
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle></svg>
							</a>
						</div>
					</div>
				</div>

				<div class="bg-card border rounded-[3rem] p-8 md:p-12 shadow-2xl">
					<form class="space-y-6" onsubmit="event.preventDefault(); alert('تم إرسال رسالتك بنجاح! سنتواصل معك قريباً.');">
						<div class="space-y-2">
							<label class="font-black font-cairo mr-2">الاسم بالكامل</label>
							<input type="text" placeholder="مثال: أحمد علي" class="w-full h-14 px-6 rounded-2xl bg-muted border-none focus:ring-2 focus:ring-primary font-bold font-cairo" required />
						</div>
						<div class="space-y-2">
							<label class="font-black font-cairo mr-2">البريد الإلكتروني</label>
							<input type="email" placeholder="email@example.com" class="w-full h-14 px-6 rounded-2xl bg-muted border-none focus:ring-2 focus:ring-primary font-bold font-cairo" required />
						</div>
						<div class="space-y-2">
							<label class="font-black font-cairo mr-2">الموضوع</label>
							<select class="w-full h-14 px-6 rounded-2xl bg-muted border-none focus:ring-2 focus:ring-primary font-bold font-cairo">
								<option>استفسار عن كورس</option>
								<option>طلب مراجعة خاصة</option>
								<option>مشكلة تقنية</option>
								<option>أخرى</option>
							</select>
						</div>
						<div class="space-y-2">
							<label class="font-black font-cairo mr-2">رسالتك</label>
							<textarea rows="4" placeholder="كيف يمكننا مساعدتك؟" class="w-full p-6 rounded-2xl bg-muted border-none focus:ring-2 focus:ring-primary font-bold font-cairo" required></textarea>
						</div>
						<button type="submit" class="w-full h-16 rounded-full bg-primary text-white font-black text-xl shadow-lg hover:scale-105 transition-all">إرسال الرسالة</button>
					</form>
				</div>

			</div>
		</div>
	</section>
</MainLayout>
