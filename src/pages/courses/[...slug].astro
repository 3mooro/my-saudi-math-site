---
import { getCollection, render } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { WHATSAPP_NUMBER } from '../../consts';

export async function getStaticPaths() {
	const courses = await getCollection('courses');
	return courses.map((course) => ({
		params: { slug: course.id },
		props: course,
	}));
}

const course = Astro.props;
const { title, instructor, rating, image, tag, packages = [], syllabus = [] } = course.data;
const { Content } = await render(course);
---

<MainLayout title={`${title} | أكاديمية KSA`} description={`اشترك الآن في باقات ${title} مع ${instructor}. أفضل شرح للمناهج السعودية أون لاين.`}>
	<section class="py-12 md:py-24 bg-background">
		<div class="container mx-auto px-4">
			<Breadcrumbs items={[{ label: 'الباقات التعليمية', href: '/#courses' }, { label: title }]} />
			
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-16">
				
				<!-- Right Side: Content -->
				<div class="lg:col-span-2 space-y-12">
					<div class="space-y-6">
						<div class="flex flex-wrap items-center gap-4">
							<span class="px-4 py-1.5 bg-primary/10 text-primary text-sm font-black rounded-full font-cairo">
								{tag}
							</span>
							<div class="flex items-center gap-2 text-yellow-400 font-bold">
								<span>★</span>
								<span class="text-foreground">{rating} (تقييم ممتاز)</span>
							</div>
						</div>
						<h1 class="text-4xl md:text-7xl font-cairo font-black tracking-tight leading-tight">
							باقات <span class="text-gradient">{title}</span>
						</h1>
						<p class="text-xl md:text-2xl text-muted-foreground font-bold leading-relaxed">
							نخبة من المعلمين المعتمدين لمساعدتك في فهم مادة {title} بأحدث الوسائل التعليمية التفاعلية.
						</p>
					</div>

					<div class="aspect-video rounded-[3rem] overflow-hidden shadow-2xl border-8 border-card reveal relative group">
						<img src={image} alt={title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
						<div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
					</div>

					<!-- Syllabus Section -->
					{syllabus.length > 0 && (
						<div class="space-y-8 reveal">
							<h2 class="text-3xl md:text-4xl font-black font-cairo">خطة المنهج الدراسي</h2>
							<div class="space-y-4">
								{syllabus.map((unit, index) => (
									<div class="group border-2 border-primary/5 rounded-[2rem] bg-card overflow-hidden transition-all hover:border-primary/20">
										<details class="w-full" open={index === 0}>
											<summary class="flex items-center justify-between p-6 md:p-8 cursor-pointer list-none">
												<div class="flex items-center gap-4">
													<div class="w-12 h-12 rounded-2xl bg-primary text-white flex items-center justify-center font-black text-xl shadow-lg shadow-primary/20">
														{index + 1}
													</div>
													<h3 class="text-xl md:text-2xl font-black font-cairo">{unit.unit}</h3>
												</div>
												<span class="text-primary transition-transform group-open:rotate-180">
													<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
												</span>
											</summary>
											<div class="px-8 pb-8 md:px-12 md:pb-10 border-t border-primary/5 pt-6">
												<ul class="space-y-4">
													{unit.lessons.map(lesson => (
														<li class="flex items-center gap-4 text-muted-foreground font-bold text-lg">
															<div class="w-2 h-2 rounded-full bg-primary/40"></div>
															{lesson}
														</li>
													))}
												</ul>
											</div>
										</details>
									</div>
								))}
							</div>
						</div>
					)}

					<div class="space-y-8">
						<h2 class="text-3xl md:text-4xl font-black font-cairo">تفاصيل الدراسة والمميزات</h2>
						<div class="prose prose-xl dark:prose-invert max-w-none font-cairo leading-loose text-justify text-muted-foreground font-bold">
							<Content />
							{!course.body && (
								<p>نقدم لك شرحاً وافياً للمنهج مع التركيز على المهارات الأساسية وتطبيقاتها العملية، مع توفير مراجعات دورية لضمان تثبيت المعلومة.</p>
							)}
						</div>
					</div>

					<!-- Learning Features Grid -->
					<div class="grid grid-cols-1 sm:grid-cols-2 gap-6 pt-12">
						{[
							{ title: "شرح تفاعلي", desc: "استخدام السبورة الذكية والوسائل البصرية", icon: "✨" },
							{ title: "متابعة الواجبات", desc: "حل وتصحيح التمارين المدرسية دورياً", icon: "📝" },
							{ title: "نماذج اختبارات", desc: "التدريب على أحدث نماذج الاختبارات النهائية", icon: "📊" },
							{ title: "تقارير أداء", desc: "إرسال تقارير دورية لولي الأمر عن مستوى الطالب", icon: "📈" }
						].map(feat => (
							<div class="p-8 rounded-[2.5rem] bg-card border border-primary/5 flex items-start gap-6">
								<div class="text-4xl">{feat.icon}</div>
								<div class="space-y-2">
									<h4 class="text-xl font-black font-cairo">{feat.title}</h4>
									<p class="text-muted-foreground font-bold text-sm leading-relaxed">{feat.desc}</p>
								</div>
							</div>
						))}
					</div>
				</div>

				<!-- Left Side: Pricing Sidebar -->
				<div class="lg:col-span-1">
					<div class="sticky top-32 space-y-8">
						<h2 class="text-3xl font-black font-cairo">اختر الباقة المناسبة</h2>
						
						<div class="space-y-4">
							{packages.map((pkg) => (
								<div class:list={[
									"relative p-8 rounded-[2.5rem] border-2 transition-all hover:scale-[1.02]",
									pkg.isUrgent 
										? "bg-secondary/5 border-secondary/20 shadow-secondary/5" 
										: pkg.sessions === 8 
											? "bg-primary/5 border-primary shadow-xl shadow-primary/10 ring-4 ring-primary/5" 
											: "bg-card border-primary/5 shadow-sm"
								]}>
									{pkg.sessions === 8 && (
										<span class="absolute -top-4 left-1/2 -translate-x-1/2 bg-primary text-white text-xs font-black px-6 py-2 rounded-full shadow-lg whitespace-nowrap">
											الباقة الأكثر طلباً
										</span>
									)}
									
									<div class="flex flex-col space-y-4">
										<div class="flex items-center justify-between">
											<h3 class="text-2xl font-black font-cairo">{pkg.name}</h3>
											<div class="text-left">
												<span class="text-3xl font-black text-primary">{pkg.totalPrice}</span>
												<span class="text-xs font-bold text-muted-foreground"> ر.س</span>
											</div>
										</div>
										
										<p class="text-sm text-muted-foreground font-bold">
											{pkg.sessions} حصص تفاعلية مباشرة • {pkg.pricePerSession} ر.س للحصة
										</p>

										<ul class="space-y-3 py-4 border-y border-primary/5">
											{pkg.features.map(feat => (
												<li class="flex items-center gap-3 text-sm font-bold text-foreground/80">
													<svg class="text-primary shrink-0" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
													{feat}
												</li>
											))}
										</ul>

										<a 
											href={`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent('مرحباً، أود الاشتراك في باقة: ' + pkg.name + ' لمادة ' + title)}`} 
											class:list={[
												"w-full h-16 items-center justify-center flex rounded-2xl text-lg font-black shadow-xl transition-all active:scale-95 font-cairo",
												pkg.isUrgent ? "bg-secondary text-white" : "bg-primary text-white"
											]}
											target="_blank"
										>
											اشترك الآن
										</a>
									</div>
								</div>
							))}
						</div>

						<!-- Trust Badges -->
						<div class="bg-muted/30 p-8 rounded-[2.5rem] border border-primary/5 text-center space-y-4">
							<p class="text-sm font-bold text-muted-foreground">انضم لآلاف المتفوقين في أكاديمية KSA</p>
							<div class="flex justify-center -space-x-3 space-x-reverse">
								{[1,2,3,4,5].map(i => (
									<img src={`https://i.pravatar.cc/100?u=${i+10}`} class="w-10 h-10 rounded-full border-2 border-card" alt="طالب" />
								))}
							</div>
						</div>
					</div>
				</div>

			</div>
		</div>
	</section>
</MainLayout>

<style>
	summary::-webkit-details-marker {
		display: none;
	}
</style>
