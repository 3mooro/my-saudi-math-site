---
import { WHATSAPP_NUMBER } from '../consts';
---
<section class="relative py-16 lg:py-24 bg-background overflow-hidden border-b border-primary/5">
	<!-- Modern Geometric Pattern Background -->
	<div class="absolute inset-0 z-0 opacity-[0.03] dark:opacity-[0.05] pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg width=\"60\" height=\"60\" viewBox=\"0 0 60 60\" xmlns=\"http://www.w3.org/2000/svg\"%3E%3Cg fill=\"none\" fill-rule=\"evenodd\"%3E%3Cg fill=\"%233b82f6\" fill-opacity=\"1\"%3E%3Cpath d=\"M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4v-4H4v4H0v2h4v4h2v-4h4v-2H6zM36 4v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4z\"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>

	<div class="container mx-auto px-4 relative z-10">
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
			
			<!-- Right: Text Content -->
			<div class="space-y-10 text-right order-2 lg:order-1">
				<div class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-primary/5 border border-primary/10 text-primary font-black text-sm animate-fade-in shadow-sm">
					<span class="relative flex h-2.5 w-2.5">
						<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
						<span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-primary"></span>
					</span>
					المنصة التعليمية الأولى للمناهج السعودية
				</div>
				
				<div class="space-y-6">
					<h1 class="font-cairo text-5xl md:text-7xl lg:text-8xl font-black tracking-tight leading-[1.1] text-foreground">
						مستقبلك يبدأ مع <br />
						<span class="text-gradient">أفضل المعلمين</span>
					</h1>
					
					<p class="text-xl md:text-2xl text-muted-foreground font-bold leading-relaxed max-w-2xl">
						دروس خصوصية تفاعلية بأسعار تنافسية تبدأ من <span class="text-primary font-black">25 ريال</span> فقط للحصة. نضمن لك الفهم الكامل والتميز الدراسي.
					</p>
				</div>
				
				<div class="flex flex-wrap gap-6 pt-4">
					<a 
						href="#courses" 
						class="h-20 px-12 items-center justify-center flex rounded-3xl bg-zinc-900 dark:bg-white dark:text-zinc-900 text-white text-2xl font-black shadow-2xl hover:scale-105 active:scale-95 transition-all font-cairo group"
					>
						ابدأ الآن 
						<span class="mr-3 group-hover:-translate-x-2 transition-transform">←</span>
					</a>
					<a 
						href={`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent('مرحباً، أحتاج جلسة طارئة لمراجعة الرياضيات')}`} 
						class="h-20 px-12 items-center justify-center flex rounded-3xl border-2 border-primary/20 bg-card text-primary text-2xl font-black hover:bg-primary/5 transition-all font-cairo shadow-lg"
						target="_blank"
					>
						جلسة طارئة
					</a>
				</div>

				<!-- Stats / Trust -->
				<div class="flex items-center gap-10 pt-10 border-t border-primary/5">
					<div class="flex flex-col">
						<span class="text-3xl font-black text-foreground">+15,000</span>
						<span class="text-sm text-muted-foreground font-bold uppercase tracking-widest">حصة منجزة</span>
					</div>
					<div class="w-px h-12 bg-primary/10"></div>
					<div class="flex flex-col">
						<div class="flex items-center gap-1">
							<span class="text-3xl font-black text-foreground">4.9</span>
							<span class="text-yellow-400 text-2xl">★</span>
						</div>
						<span class="text-sm text-muted-foreground font-bold uppercase tracking-widest">تقييم أولياء الأمور</span>
					</div>
				</div>
			</div>

			<!-- Left: Image/Illustration -->
			<div class="order-1 lg:order-2 relative reveal">
				<div class="relative z-10 rounded-[4rem] overflow-hidden shadow-[0_50px_100px_rgba(59,130,246,0.2)] border-[12px] border-card transform lg:rotate-2 hover:rotate-0 transition-transform duration-700">
					<img 
						src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&q=80&w=1000" 
						alt="تعلم أونلاين" 
						class="w-full h-auto scale-105"
					/>
					<!-- Overlay Gradient -->
					<div class="absolute inset-0 bg-gradient-to-tr from-primary/20 to-transparent pointer-events-none"></div>
				</div>
				<!-- Floating Decorative Elements -->
				<div class="absolute -top-12 -right-12 w-48 h-48 bg-primary/20 rounded-full blur-[100px] animate-pulse"></div>
				<div class="absolute -bottom-12 -left-12 w-48 h-48 bg-secondary/20 rounded-full blur-[100px] animate-pulse delay-1000"></div>
				
				<!-- Floating Card -->
				<div class="absolute -bottom-8 -right-8 bg-card p-6 rounded-[2rem] shadow-2xl border border-primary/10 z-20 hidden md:flex items-center gap-4 animate-float">
					<div class="w-12 h-12 rounded-2xl bg-green-500/10 text-green-500 flex items-center justify-center">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
					</div>
					<div>
						<div class="text-sm font-black font-cairo leading-none">معلمون معتمدون</div>
						<div class="text-[10px] text-muted-foreground font-bold mt-1">أكثر من 500 خبير</div>
					</div>
				</div>
			</div>

		</div>
	</div>
</section>
