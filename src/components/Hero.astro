---
---
<section class="relative overflow-hidden py-24 md:py-32 lg:py-40">
	<!-- Background Elements -->
	<div class="absolute inset-0 -z-10 bg-[radial-gradient(45%_45%_at_50%_50%,rgba(59,130,246,0.1)_0%,rgba(255,255,255,0)_100%)]"></div>
	<div class="absolute top-0 left-1/4 -z-10 h-[400px] w-[400px] rounded-full bg-primary/10 blur-[100px] animate-float"></div>
	<div class="absolute bottom-0 right-1/4 -z-10 h-[300px] w-[300px] rounded-full bg-secondary/10 blur-[80px] animate-float" style="animation-delay: -3s"></div>

	<div class="container mx-auto px-4 text-center">
		<div class="mx-auto max-w-4xl space-y-8">
			<div class="inline-flex items-center rounded-full border border-primary/20 bg-primary/5 px-4 py-1.5 text-sm font-medium text-primary mb-4 animate-in fade-in slide-in-from-bottom-4 duration-1000">
				<span class="mr-2">✨</span>
				New: Interactive Math Courses Now Live
			</div>
			
			<h1 class="font-poppins text-5xl md:text-7xl font-extrabold tracking-tight text-gradient animate-in fade-in slide-in-from-bottom-8 duration-1000 delay-100">
				Start Learning Smarter,<br /> Not Harder
			</h1>
			
			<p class="mx-auto max-w-2xl text-lg md:text-xl text-muted-foreground leading-relaxed animate-in fade-in slide-in-from-bottom-12 duration-1000 delay-200">
				Master mathematics and sciences with our premium educational platform. Expert-led courses, personalized support, and interactive tools designed for your success.
			</p>
			
			<div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-in fade-in slide-in-from-bottom-16 duration-1000 delay-300">
				<a 
					href="/blog" 
					class="w-full sm:w-auto h-14 items-center justify-center inline-flex rounded-full bg-primary px-8 text-lg font-semibold text-primary-foreground shadow-lg transition-all hover:bg-primary/90 hover:scale-105 active:scale-95"
				>
					Browse Courses
				</a>
				<a 
					href="/about" 
					class="w-full sm:w-auto h-14 items-center justify-center inline-flex rounded-full border-2 border-primary/20 bg-transparent px-8 text-lg font-semibold transition-all hover:bg-primary/5 hover:border-primary/40"
				>
					Learn More
				</a>
			</div>
			
			<!-- Dashboard Preview Illustration -->
			<div class="mt-16 relative mx-auto max-w-5xl rounded-2xl border bg-card p-2 shadow-2xl animate-in fade-in zoom-in duration-1000 delay-500">
				<div class="rounded-xl overflow-hidden glass aspect-video flex items-center justify-center bg-muted/20">
					<!-- This would be a real image or a more complex SVG/UI mockup -->
					<div class="text-muted-foreground flex flex-col items-center">
						<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="mb-4 opacity-20"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"></rect><line x1="3" x2="21" y1="9" y2="9"></line><line x1="9" x2="9" y1="21" y2="9"></line></svg>
						<span class="font-medium tracking-widest uppercase text-xs">Interactive Dashboard Preview</span>
					</div>
				</div>
				<!-- Decorative elements -->
				<div class="absolute -top-4 -right-4 h-24 w-24 rounded-lg bg-secondary/20 blur-2xl"></div>
				<div class="absolute -bottom-4 -left-4 h-24 w-24 rounded-lg bg-primary/20 blur-2xl"></div>
			</div>
		</div>
	</div>
</section>
