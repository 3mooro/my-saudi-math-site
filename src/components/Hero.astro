---
import { WHATSAPP_NUMBER } from '../consts';
---
<section class="relative py-16 lg:py-24 bg-background overflow-hidden border-b border-primary/5">
	<div class="container mx-auto px-4">
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
			
			<!-- Right: Text Content -->
			<div class="space-y-8 text-right order-2 lg:order-1">
				<div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/5 border border-primary/10 text-primary font-black text-sm animate-fade-in">
					<span class="relative flex h-2 w-2">
						<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
						<span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
					</span>
					منصة تعليمية متكاملة للمناهج السعودية
				</div>
				
				<h1 class="font-cairo text-4xl md:text-6xl lg:text-7xl font-black tracking-tight leading-tight text-foreground">
					دروس خصوصية أون لاين مع <br />
					<span class="text-primary">نخبة من المعلمين</span>
				</h1>
				
				<p class="text-xl md:text-2xl text-muted-foreground font-bold leading-relaxed max-w-2xl">
					نقدم لك تجربة تعليمية فريدة تجمع بين الجودة، المرونة، والأسعار المناسبة لجميع المراحل الدراسية.
				</p>
				
				<div class="flex flex-wrap gap-4 pt-4">
					<a 
						href="#courses" 
						class="h-16 px-10 items-center justify-center flex rounded-2xl bg-zinc-900 dark:bg-white dark:text-zinc-900 text-white text-xl font-black shadow-2xl hover:scale-105 active:scale-95 transition-all font-cairo"
					>
						ابدأ رحلتك الآن
					</a>
					<a 
						href={`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent('مرحباً، أحتاج جلسة طارئة لمراجعة الرياضيات')}`} 
						class="h-16 px-10 items-center justify-center flex rounded-2xl border-2 border-primary/20 bg-card text-primary text-xl font-black hover:bg-primary/5 transition-all font-cairo"
						target="_blank"
					>
						جلسة طارئة (عاجل)
					</a>
				</div>

				<div class="flex items-center gap-6 pt-8 border-t border-primary/5">
					<div class="flex flex-col">
						<span class="text-2xl font-black text-foreground">+10k</span>
						<span class="text-xs text-muted-foreground font-bold uppercase">طالب نشط</span>
					</div>
					<div class="w-px h-8 bg-primary/10"></div>
					<div class="flex flex-col">
						<span class="text-2xl font-black text-foreground">4.9/5</span>
						<span class="text-xs text-muted-foreground font-bold uppercase">تقييم المنصة</span>
					</div>
				</div>
			</div>

			<!-- Left: Image/Illustration -->
			<div class="order-1 lg:order-2 relative reveal">
				<div class="relative z-10 rounded-[3rem] overflow-hidden shadow-[0_50px_100px_rgba(59,130,246,0.15)] border-8 border-card">
					<img 
						src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&q=80&w=1000" 
						alt="تعلم أونلاين" 
						class="w-full h-auto"
					/>
				</div>
				<!-- Floating Decorative Elements -->
				<div class="absolute -top-6 -right-6 w-32 h-32 bg-primary/10 rounded-full blur-3xl animate-pulse"></div>
				<div class="absolute -bottom-6 -left-6 w-32 h-32 bg-secondary/10 rounded-full blur-3xl animate-pulse delay-1000"></div>
			</div>

		</div>
	</div>
</section>
