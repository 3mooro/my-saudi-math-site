---
---
<section class="relative overflow-hidden py-24 md:py-32 lg:py-40">
	<!-- Background Elements -->
	<div class="absolute inset-0 -z-10 bg-[radial-gradient(45%_45%_at_50%_50%,rgba(59,130,246,0.1)_0%,rgba(255,255,255,0)_100%)]"></div>
	<div class="absolute top-0 right-1/4 -z-10 h-[400px] w-[400px] rounded-full bg-primary/10 blur-[100px] animate-float"></div>
	<div class="absolute bottom-0 left-1/4 -z-10 h-[300px] w-[300px] rounded-full bg-secondary/10 blur-[80px] animate-float" style="animation-delay: -3s"></div>

	<div class="container mx-auto px-4 text-center">
		<div class="mx-auto max-w-4xl space-y-8">
			<div class="inline-flex items-center rounded-full border border-primary/20 bg-primary/5 px-4 py-1.5 text-sm font-bold text-primary mb-4 animate-in fade-in slide-in-from-bottom-4 duration-1000">
				<span class="ml-2">✨</span>
				جديد: انطلاق كورسات الرياضيات التفاعلية
			</div>
			
			<h1 class="font-cairo text-5xl md:text-7xl font-extrabold tracking-tight text-gradient animate-in fade-in slide-in-from-bottom-8 duration-1000 delay-100 leading-tight">
				تعلم بذكاء،<br /> وليس بجهد مضاعف
			</h1>
			
			<p class="mx-auto max-w-2xl text-lg md:text-xl text-muted-foreground leading-relaxed animate-in fade-in slide-in-from-bottom-12 duration-1000 delay-200">
				أتقن الرياضيات والعلوم مع منصتنا التعليمية الرائدة. نقدم لك دورات بشرح خبراء، ودعم مستمر، وأدوات تفاعلية مصممة خصيصاً لضمان تفوقك الدراسي.
			</p>
			
			<div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-in fade-in slide-in-from-bottom-16 duration-1000 delay-300">
				<a 
					href="https://wa.me/201210603349?text=%D9%85%D8%B1%D8%AD%D8%A8%D8%A7%D8%8C%20%D8%A3%D8%B1%D9%8A%D8%AF%20%D8%A7%D9%84%D8%A7%D8%B3%D8%AA%D9%81%D8%B3%D8%A7%D8%B1%20%D8%B9%D9%86%20%D8%A7%D9%84%D9%83%D9%88%D8%B1%D8%B3%D8%A7%D8%AA" 
					class="w-full sm:w-auto h-14 items-center justify-center inline-flex rounded-full bg-primary px-8 text-lg font-bold text-primary-foreground shadow-lg transition-all hover:bg-primary/90 hover:scale-105 active:scale-95 font-cairo"
					target="_blank"
				>
					ابدأ الآن
				</a>
				<a 
					href="/about" 
					class="w-full sm:w-auto h-14 items-center justify-center inline-flex rounded-full border-2 border-primary/20 bg-transparent px-8 text-lg font-bold transition-all hover:bg-primary/5 hover:border-primary/40 font-cairo"
				>
					اعرف المزيد
				</a>
			</div>
			
			<!-- Dashboard Preview Illustration -->
			<div class="mt-16 relative mx-auto max-w-5xl rounded-2xl border bg-card p-2 shadow-2xl animate-in fade-in zoom-in duration-1000 delay-500">
				<div class="rounded-xl overflow-hidden glass aspect-video flex items-center justify-center bg-muted/20 relative group">
					<!-- Math Illustration Placeholder -->
					<div class="absolute inset-0 bg-gradient-to-tr from-primary/10 to-secondary/10 opacity-50 group-hover:opacity-100 transition-opacity"></div>
					<div class="text-muted-foreground flex flex-col items-center z-10">
						<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mb-4 text-primary/60 group-hover:text-primary transition-colors"><path d="M21.54 15H17a2 2 0 0 0-2 2v4.54"></path><path d="M7 3.34V5a3 3 0 0 0 3 3v0a2 2 0 0 1 2 2v0c0 1.1.9 2 2 2v0a2 2 0 0 0 2-2v0c0-1.1.9-2 2-2h1.66"></path><path d="M11 21.54V20a2 2 0 0 0-2-2H4.46"></path><circle cx="12" cy="12" r="10"></circle></svg>
						<span class="font-cairo font-bold tracking-wider text-sm text-primary/80">لوحة تحكم الطالب التفاعلية</span>
					</div>
				</div>
				<!-- Decorative elements -->
				<div class="absolute -top-4 -left-4 h-24 w-24 rounded-lg bg-secondary/20 blur-2xl"></div>
				<div class="absolute -bottom-4 -right-4 h-24 w-24 rounded-lg bg-primary/20 blur-2xl"></div>
			</div>
		</div>
	</div>
</section>
