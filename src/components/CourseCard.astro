---
import { WHATSAPP_NUMBER } from '../consts';

interface Package {
	name: string;
	sessions: number;
	pricePerSession: number;
	totalPrice: number;
	features: string[];
	isUrgent?: boolean;
}

interface Props {
	title: string;
	instructor: string;
	rating: number;
	image: string;
	tag: string;
	id: string;
	packages?: Package[];
}

const { title, instructor, rating, image, tag, id, packages = [] } = Astro.props;
---
<div class="group relative rounded-[3rem] bg-card border border-primary/10 p-8 transition-all duration-500 hover:shadow-[0_30px_100px_rgba(59,130,246,0.15)] flex flex-col h-full reveal">
	
	<!-- Header Info -->
	<div class="flex items-start justify-between mb-8">
		<div class="space-y-2">
			<span class="px-4 py-1 bg-primary/10 text-primary text-xs font-black rounded-full font-cairo">
				{tag}
			</span>
			<h3 class="font-cairo font-black text-3xl lg:text-4xl text-foreground group-hover:text-primary transition-colors leading-tight">
				{title}
			</h3>
			<div class="flex items-center gap-2 text-muted-foreground font-bold text-sm">
				<span>بواسطة {instructor}</span>
				<span>•</span>
				<div class="flex items-center gap-1">
					<span class="text-yellow-400">★</span>
					<span>{rating}</span>
				</div>
			</div>
		</div>
		<div class="w-20 h-20 rounded-[2rem] overflow-hidden border-2 border-primary/10 shadow-lg">
			<img src={image} alt={title} class="w-full h-full object-cover" />
		</div>
	</div>

	<!-- Packages Comparison -->
	<div class="grid grid-cols-1 gap-4 flex-grow">
		{packages.map((pkg) => (
			<div class:list={[
				"relative p-6 rounded-[2rem] border-2 transition-all group/pkg",
				pkg.isUrgent 
					? "bg-secondary/5 border-secondary/20 hover:bg-secondary/10" 
					: pkg.sessions === 8 
						? "bg-primary/5 border-primary/20 hover:bg-primary/10" 
						: "bg-muted/30 border-transparent hover:border-primary/10"
			]}>
				{pkg.isUrgent && (
					<span class="absolute -top-3 right-6 bg-secondary text-white text-[10px] font-black px-3 py-1 rounded-full shadow-lg">عاجل اليوم</span>
				)}
				{pkg.sessions === 8 && (
					<span class="absolute -top-3 right-6 bg-primary text-white text-[10px] font-black px-3 py-1 rounded-full shadow-lg">الأكثر توفيراً</span>
				)}
				
				<div class="flex items-center justify-between gap-4">
					<div class="flex flex-col">
						<span class="text-lg font-black font-cairo">{pkg.name}</span>
						<span class="text-xs text-muted-foreground font-bold">{pkg.sessions} حصص تفاعلية (60 دقيقة)</span>
					</div>
					<div class="text-left">
						<div class="text-2xl font-black text-foreground leading-none">{pkg.totalPrice} <span class="text-xs">ر.س</span></div>
						<div class="text-[10px] text-muted-foreground font-bold mt-1">({pkg.pricePerSession} ر.س / حصة)</div>
					</div>
				</div>

				<div class="mt-4">
					<a 
						href={`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent('مرحباً، أود الاشتراك في باقة: ' + pkg.name + ' لمادة ' + title)}`} 
						class:list={[
							"w-full h-12 flex items-center justify-center rounded-2xl font-black font-cairo text-sm transition-all shadow-md active:scale-95",
							pkg.isUrgent ? "bg-secondary text-white hover:bg-secondary/90" : "bg-primary text-white hover:bg-primary/90"
						]}
						target="_blank"
					>
						اشترك في الباقة
					</a>
				</div>
			</div>
		))}
	</div>

	<div class="mt-8 pt-6 border-t border-primary/5 text-center">
		<a href={`/courses/${id}`} class="text-muted-foreground hover:text-primary font-black text-sm font-cairo transition-colors flex items-center justify-center gap-2">
			تفاصيل إضافية عن المنهج والمدرس
			<span>←</span>
		</a>
	</div>
</div>
