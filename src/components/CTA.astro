---
---
<section class="py-24">
	<div class="container mx-auto px-4">
		<div class="relative overflow-hidden rounded-[2.5rem] bg-zinc-950 px-8 py-20 text-center shadow-2xl md:px-16">
			<!-- Abstract decorative gradients -->
			<div class="absolute -left-20 -top-20 h-64 w-64 rounded-full bg-primary/30 blur-[100px]"></div>
			<div class="absolute -right-20 -bottom-20 h-64 w-64 rounded-full bg-secondary/20 blur-[100px]"></div>
			
			<div class="relative z-10 mx-auto max-w-3xl space-y-8">
				<h2 class="text-4xl md:text-6xl font-poppins font-bold tracking-tight text-white leading-tight">
					Ready to Start Your <br /> Educational Journey?
				</h2>
				<p class="text-xl text-zinc-400 leading-relaxed">
					Join thousands of students who are already learning and growing with KSA Academy. Get unlimited access to all our courses today.
				</p>
				<div class="flex flex-col sm:flex-row items-center justify-center gap-6 pt-4">
					<a 
						href="/get-started" 
						class="h-16 w-full sm:w-auto items-center justify-center inline-flex rounded-full bg-white px-10 text-lg font-bold text-zinc-950 transition-all hover:scale-105 active:scale-95 shadow-xl shadow-white/10"
					>
						ابدأ رحلتك التعليمية الآن
					</a>
					<a 
						href="/blog" 
						class="h-16 w-full sm:w-auto items-center justify-center inline-flex rounded-full border border-zinc-700 bg-transparent px-10 text-lg font-bold text-white transition-all hover:bg-zinc-800"
					>
						Browse Courses
					</a>
				</div>
				<div class="pt-8 flex items-center justify-center gap-8 text-zinc-500 text-sm font-medium">
					<div class="flex items-center gap-2">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><polyline points="20 6 9 17 4 12"></polyline></svg>
						No credit card required
					</div>
					<div class="flex items-center gap-2">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><polyline points="20 6 9 17 4 12"></polyline></svg>
						Cancel anytime
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
