---
const tips = [
	"هل تعلم؟ الصفر هو الرقم الوحيد الذي لا يمكن تمثيله بالأرقام الرومانية.",
	"نصيحة: لحل أي مسألة معقدة، ابدأ دائماً برسم شكل توضيحي بسيط للمعطيات.",
	"حقيقة: الرقم 2 هو الرقم الأولي الزوجي الوحيد في عالم الرياضيات.",
	"سر النجاح: التدرب على حل المسائل يومياً لمدة 15 دقيقة أفضل من المذاكرة لـ 5 ساعات مرة واحدة أسبوعياً.",
	"هل تعلم؟ مجموع زوايا أي مثلث يساوي دائماً 180 درجة، مهما كان شكله!"
];
---

<section class="py-12 bg-primary/5 border-y border-primary/10">
	<div class="container mx-auto px-4">
		<div class="max-w-4xl mx-auto bg-card border-2 border-primary/20 rounded-[2rem] p-8 md:p-12 shadow-xl relative overflow-hidden group">
			<!-- Decorative Icon -->
			<div class="absolute -right-4 -top-4 text-8xl opacity-10 rotate-12 group-hover:rotate-0 transition-transform duration-500">💡</div>
			
			<div class="flex flex-col md:flex-row items-center gap-8 relative z-10">
				<div class="w-20 h-20 rounded-2xl bg-primary text-white flex items-center justify-center text-4xl shadow-lg shadow-primary/30 shrink-0">
					<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.7 1.5-1.7 1.5-2.5 0-2.2-1.8-4-4-4s-4 1.8-4 4c0 .8.5 1.8 1.5 2.5.8.8 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>
				</div>
				<div class="space-y-4 text-center md:text-right">
					<h3 class="text-xl font-black font-cairo text-primary uppercase tracking-widest">معلومة رياضية سريعة</h3>
					<p id="math-tip-text" class="text-2xl md:text-3xl font-bold font-cairo leading-relaxed">
						جاري تحميل نصيحة اليوم...
					</p>
				</div>
			</div>
		</div>
	</div>
</section>

<script define:vars={{ tips }}>
	// Rotate tips logic
	const tipText = document.getElementById('math-tip-text');
	if (tipText) {
		const randomTip = tips[Math.floor(Math.random() * tips.length)];
		tipText.innerText = randomTip;
	}
</script>
