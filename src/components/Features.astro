---
const features = [
	{
		title: "سعر مناسب",
		description: "باقات اقتصادية تناسب الجميع مع توفير كبير عند اختيار الباقات الشهرية.",
		icon: "💰"
	},
	{
		title: "إشراف أكاديمي",
		description: "فريق أكاديمي يتابع أداء المعلم وتقدم الطالب لضمان أفضل النتائج.",
		icon: "🎓"
	},
	{
		title: "مرونة الوقت",
		description: "اختر المواعيد التي تناسب جدولك اليومي بكل سهولة ويسر.",
		icon: "⏰"
	},
	{
		title: "جودة التعليم",
		description: "نستخدم أحدث التقنيات والوسائل التعليمية التفاعلية لتبسيط المعلومة.",
		icon: "✨"
	},
	{
		title: "معلمون معتمدون",
		description: "نخبة من المعلمين والمعلمات ذوي الخبرة في المناهج السعودية.",
		icon: "🏅"
	}
];
---
<section class="py-24 bg-muted/20 border-b border-primary/5">
	<div class="container mx-auto px-4">
		<div class="text-center max-w-3xl mx-auto mb-16 space-y-4">
			<h2 class="text-3xl md:text-5xl font-cairo font-black tracking-tight leading-tight text-gradient">لماذا أكاديمية KSA؟</h2>
			<p class="text-xl text-muted-foreground font-bold italic">"نبتكر لنعلم، ونشرف لنضمن التفوق"</p>
		</div>
		
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
			{features.map((feature) => (
				<div class="group p-8 rounded-[2.5rem] bg-card border border-primary/5 transition-all hover:border-primary/20 hover:shadow-2xl text-center reveal flex flex-col items-center">
					<div class="w-20 h-20 rounded-3xl bg-primary/10 text-4xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform shadow-inner">
						{feature.icon}
					</div>
					<h3 class="text-xl font-black font-cairo mb-3">{feature.title}</h3>
					<p class="text-muted-foreground font-bold text-sm leading-relaxed">{feature.description}</p>
				</div>
			))}
		</div>
	</div>
</section>
