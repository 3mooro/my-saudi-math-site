---
---
<section class="py-24 relative overflow-hidden">
	<div class="absolute inset-0 -z-10 bg-primary/5"></div>
	<div class="absolute top-0 right-0 w-96 h-96 bg-primary/10 blur-[100px] rounded-full -translate-y-1/2 translate-x-1/2"></div>
	
	<div class="container mx-auto px-4">
		<div class="max-w-5xl mx-auto bg-card border rounded-[3rem] p-8 md:p-16 shadow-2xl relative overflow-hidden">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
				
				<div class="space-y-6">
					<h2 class="text-3xl md:text-5xl font-cairo font-black tracking-tight leading-tight">
						ابقَ على اطلاع بأحدث <br /><span class="text-gradient">الكورسات والمراجعات</span>
					</h2>
					<p class="text-lg text-muted-foreground font-bold leading-relaxed">
						انضم إلى أكثر من 5000 طالب يصلهم محتوى تعليمي حصري وتنبيهات بموعد المراجعات النهائية مباشرة على إيميلاتهم.
					</p>
					<div class="flex items-center gap-4 text-sm font-bold text-primary">
						<div class="flex -space-x-3 space-x-reverse">
							{[1,2,3,4].map(i => (
								<img src={`https://i.pravatar.cc/100?u=${i}`} class="w-10 h-10 rounded-full border-2 border-card" alt="طالب" />
							))}
						</div>
						<span>انضم لزملائك المتفوقين الآن!</span>
					</div>
				</div>

				<div>
					<form class="space-y-4" onsubmit="event.preventDefault(); alert('شكراً لاهتمامك! سيتم تفعيل هذه الميزة قريباً.');">
						<div class="relative">
							<input 
								type="email" 
								placeholder="أدخل بريدك الإلكتروني هنا..." 
								class="w-full h-16 md:h-20 px-8 rounded-full bg-muted border-none focus:ring-2 focus:ring-primary text-lg font-bold font-cairo shadow-inner"
								required
							/>
							<button 
								type="submit" 
								class="md:absolute md:top-2 md:left-2 md:bottom-2 h-12 md:h-auto px-10 rounded-full bg-primary text-white font-black text-lg shadow-lg hover:scale-105 active:scale-95 transition-all mt-4 md:mt-0 w-full md:w-auto"
							>
								اشترك الآن
							</button>
						</div>
						<p class="text-xs text-muted-foreground text-center font-bold">
							نحن نحترم خصوصيتك. يمكنك إلغاء الاشتراك في أي وقت.
						</p>
					</form>
				</div>

			</div>
		</div>
	</div>
</section>
