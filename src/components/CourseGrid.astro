---
import CourseCard from './CourseCard.astro';

const courses = [
	{
		title: "التفاضل والتكامل المتقدم للهندسة",
		instructor: "د. أحمد منصور",
		rating: 4.9,
		price: "مجاني",
		image: "https://images.unsplash.com/photo-1635070041078-e363dbe005cb?w=800&q=80",
		tag: "رياضيات"
	},
	{
		title: "أساسيات فيزياء الكم",
		instructor: "أ. سارة جينكنز",
		rating: 4.8,
		price: "49.99$",
		image: "https://images.unsplash.com/photo-1636466497217-26a8cbeaf0aa?w=800&q=80",
		tag: "فيزياء"
	},
	{
		title: "إتقان الكيمياء العضوية",
		instructor: "د. إيميلي تشين",
		rating: 4.7,
		price: "39.99$",
		image: "https://images.unsplash.com/photo-1532187875605-18674534afb9?w=800&q=80",
		tag: "كيمياء"
	},
	{
		title: "هياكل البيانات والخوارزميات",
		instructor: "مارك أندريسن",
		rating: 4.9,
		price: "مجاني",
		image: "https://images.unsplash.com/photo-1515879218367-8466d910aaa4?w=800&q=80",
		tag: "علوم حاسب"
	},
	{
		title: "تطوير الويب الحديث",
		instructor: "جون دو",
		rating: 4.8,
		price: "29.99$",
		image: "https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=800&q=80",
		tag: "برمجة"
	},
	{
		title: "الفيزياء الفلكية للمبتدئين",
		instructor: "نيل ديجراس تايسون",
		rating: 5.0,
		price: "59.99$",
		image: "https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=800&q=80",
		tag: "علوم"
	}
];
---
<section class="py-24" id="courses">
	<div class="container mx-auto px-4">
		<div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
			<div class="space-y-4 max-w-xl">
				<h2 class="text-3xl md:text-5xl font-cairo font-bold tracking-tight">استكشف الكورسات الأكثر شهرة</h2>
				<p class="text-lg text-muted-foreground">اختر من بين مجموعة واسعة من الكورسات المقدمة من خبراء عالميين. ابدأ رحلتك التعليمية اليوم.</p>
			</div>
			<a href="/blog" class="text-primary font-bold hover:underline flex items-center gap-2">
				عرض كل الكورسات
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="rotate-180"><line x1="5" x2="19" y1="12" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
			</a>
		</div>
		
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
			{courses.map((course) => (
				<CourseCard {...course} />
			))}
		</div>
	</div>
</section>
