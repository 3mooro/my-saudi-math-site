---
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
import { SITE_TITLE, WHATSAPP_NUMBER } from '../consts';
---

<header class="sticky top-0 z-50 w-full border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60 transition-colors duration-300">
	<div class="container mx-auto flex h-20 md:h-24 items-center justify-between px-6">
		<div class="flex items-center gap-2">
			<a href="/" class="flex items-center space-x-2 space-x-reverse group">
				<span class="inline-block font-cairo font-black text-2xl sm:text-3xl lg:text-4xl text-gradient transition-transform group-hover:scale-105">
					{SITE_TITLE}
				</span>
			</a>
		</div>
		
		<!-- Desktop Navigation -->
		<nav class="hidden md:flex items-center gap-10 text-lg lg:text-xl font-bold">
			<HeaderLink href="/" class="hover:scale-105 transition-transform">الرئيسية</HeaderLink>
			<HeaderLink href="/blog" class="hover:scale-105 transition-transform">الكورسات</HeaderLink>
			<HeaderLink href="/about" class="hover:scale-105 transition-transform">عن الأكاديمية</HeaderLink>
			<HeaderLink href="/contact" class="hover:scale-105 transition-transform">اتصل بنا</HeaderLink>
		</nav>

		<div class="flex items-center gap-6">
			<div class="scale-125 lg:scale-150">
				<ThemeToggle />
			</div>
			<a 
				href={`https://wa.me/${WHATSAPP_NUMBER}?text=%D9%85%D8%B1%D8%AD%D8%A8%D8%A7%D8%8C%20%D8%A3%D8%B1%D9%8A%D8%AF%20%D8%A7%D9%84%D8%A7%D8%B3%D8%AA%D9%81%D8%B3%D8%A7%D8%B1%20%D8%B9%D9%86%20%D8%A7%D9%84%D9%83%D9%88%D8%B1%D8%B3%D8%A7%D8%AA`} 
				class="hidden sm:inline-flex h-12 md:h-14 items-center justify-center rounded-full bg-primary px-8 md:px-10 text-lg md:text-xl font-black text-primary-foreground shadow-xl shadow-primary/20 transition-all hover:bg-primary/90 hover:scale-105 active:scale-95 font-cairo"
				target="_blank"
			>
				ابدأ الآن
			</a>
			<!-- Mobile Menu Button -->
			<button id="mobile-menu-open" class="md:hidden inline-flex items-center justify-center rounded-xl p-3 text-muted-foreground hover:bg-accent hover:text-accent-foreground transition-colors scale-125 border border-primary/10">
				<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg>
				<span class="sr-only">فتح القائمة</span>
			</button>
		</div>
	</div>

	<!-- Mobile Menu Drawer -->
	<div id="mobile-menu" class="fixed inset-0 z-[100] bg-background/80 backdrop-blur-md translate-x-full transition-transform duration-500 md:hidden">
		<div class="fixed inset-y-0 right-0 w-full max-w-sm bg-card shadow-2xl border-l p-8 flex flex-col">
			<div class="flex items-center justify-between mb-12">
				<span class="font-cairo font-black text-2xl text-gradient">{SITE_TITLE}</span>
				<button id="mobile-menu-close" class="p-3 rounded-xl hover:bg-accent text-muted-foreground transition-colors border border-primary/10">
					<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" x2="6" y1="6" y2="18"></line><line x1="6" x2="18" y1="6" y2="18"></line></svg>
				</button>
			</div>
			
			<nav class="flex flex-col gap-6 text-2xl font-black font-cairo mb-auto">
				<a href="/" class="hover:text-primary transition-colors flex items-center justify-between">الرئيسية <span>←</span></a>
				<a href="/blog" class="hover:text-primary transition-colors flex items-center justify-between">الكورسات <span>←</span></a>
				<a href="/about" class="hover:text-primary transition-colors flex items-center justify-between">عن الأكاديمية <span>←</span></a>
				<a href="/contact" class="hover:text-primary transition-colors flex items-center justify-between">اتصل بنا <span>←</span></a>
			</nav>

			<div class="pt-8 border-t border-primary/10 space-y-6">
				<a 
					href={`https://wa.me/${WHATSAPP_NUMBER}`} 
					class="w-full h-16 items-center justify-center flex rounded-full bg-primary text-white text-xl font-black shadow-xl font-cairo"
					target="_blank"
				>
					ابدأ الآن (واتساب)
				</a>
				<div class="flex justify-center gap-6 text-muted-foreground">
					<!-- Social Links could go here -->
				</div>
			</div>
		</div>
	</div>
</header>

<script>
	const openBtn = document.getElementById('mobile-menu-open');
	const closeBtn = document.getElementById('mobile-menu-close');
	const menu = document.getElementById('mobile-menu');

	const toggleMenu = () => {
		menu?.classList.toggle('translate-x-full');
		document.body.classList.toggle('overflow-hidden');
	};

	openBtn?.addEventListener('click', toggleMenu);
	closeBtn?.addEventListener('click', toggleMenu);

	// Close menu on link click
	const links = menu?.querySelectorAll('nav a');
	links?.forEach(link => {
		link.addEventListener('click', toggleMenu);
	});
</script>
