---
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
import { SITE_TITLE } from '../consts';
---

<header class="sticky top-0 z-40 w-full border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60 transition-colors duration-300">
	<div class="container mx-auto flex h-16 items-center justify-between px-4">
		<div class="flex items-center gap-2">
			<a href="/" class="flex items-center space-x-2 space-x-reverse">
				<span class="inline-block font-cairo font-bold text-xl sm:text-2xl text-gradient">
					{SITE_TITLE}
				</span>
			</a>
		</div>
		
		<nav class="hidden md:flex items-center gap-6 text-sm font-medium">
			<HeaderLink href="/">الرئيسية</HeaderLink>
			<HeaderLink href="/blog">الكورسات</HeaderLink>
			<HeaderLink href="/about">عن الأكاديمية</HeaderLink>
		</nav>

		<div class="flex items-center gap-4">
			<ThemeToggle />
			<a 
				href="https://wa.me/201210603349?text=%D9%85%D8%B1%D8%AD%D8%A8%D8%A7%D8%8C%20%D8%A3%D8%B1%D9%8A%D8%AF%20%D8%A7%D9%84%D8%A7%D8%B3%D8%AA%D9%81%D8%B3%D8%A7%D8%B1%20%D8%B9%D9%86%20%D8%A7%D9%84%D9%83%D9%88%D8%B1%D8%B3%D8%A7%D8%AA" 
				class="hidden sm:inline-flex h-10 items-center justify-center rounded-full bg-primary px-6 text-sm font-bold text-primary-foreground shadow transition-colors hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 font-cairo"
				target="_blank"
			>
				ابدأ الآن
			</a>
			<button class="md:hidden inline-flex items-center justify-center rounded-md p-2 text-muted-foreground hover:bg-accent hover:text-accent-foreground">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg>
				<span class="sr-only">تبديل القائمة</span>
			</button>
		</div>
	</div>
</header>
