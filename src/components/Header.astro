---
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
import { SITE_TITLE, WHATSAPP_NUMBER } from '../consts';
---

<header class="sticky top-0 z-40 w-full border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60 transition-colors duration-300">
	<div class="container mx-auto flex h-20 md:h-24 items-center justify-between px-6">
		<div class="flex items-center gap-2">
			<a href="/" class="flex items-center space-x-2 space-x-reverse group">
				<span class="inline-block font-cairo font-black text-2xl sm:text-3xl lg:text-4xl text-gradient transition-transform group-hover:scale-105">
					{SITE_TITLE}
				</span>
			</a>
		</div>
		
		<nav class="hidden md:flex items-center gap-10 text-lg lg:text-xl font-bold">
			<HeaderLink href="/" class="hover:scale-105 transition-transform">الرئيسية</HeaderLink>
			<HeaderLink href="/blog" class="hover:scale-105 transition-transform">الكورسات</HeaderLink>
			<HeaderLink href="/about" class="hover:scale-105 transition-transform">عن الأكاديمية</HeaderLink>
			<HeaderLink href="/contact" class="hover:scale-105 transition-transform">اتصل بنا</HeaderLink>
		</nav>

		<div class="flex items-center gap-6">
			<div class="scale-125 lg:scale-150">
				<ThemeToggle />
			</div>
			<a 
				href={`https://wa.me/${WHATSAPP_NUMBER}?text=%D9%85%D8%B1%D8%AD%D8%A8%D8%A7%D8%8C%20%D8%A3%D8%B1%D9%8A%D8%AF%20%D8%A7%D9%84%D8%A7%D8%B3%D8%AA%D9%81%D8%B3%D8%A7%D8%B1%20%D8%B9%D9%86%20%D8%A7%D9%84%D9%83%D9%88%D8%B1%D8%B3%D8%A7%D8%AA`} 
				class="hidden sm:inline-flex h-12 md:h-14 items-center justify-center rounded-full bg-primary px-8 md:px-10 text-lg md:text-xl font-black text-primary-foreground shadow-xl shadow-primary/20 transition-all hover:bg-primary/90 hover:scale-105 active:scale-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary disabled:pointer-events-none disabled:opacity-50 font-cairo"
				target="_blank"
			>
				ابدأ الآن
			</a>
			<button class="md:hidden inline-flex items-center justify-center rounded-md p-3 text-muted-foreground hover:bg-accent hover:text-accent-foreground transition-colors scale-125">
				<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg>
				<span class="sr-only">تبديل القائمة</span>
			</button>
		</div>
	</div>
</header>
