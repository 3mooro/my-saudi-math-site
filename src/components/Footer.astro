---
import { SITE_TITLE, TWITTER_LINK, INSTAGRAM_LINK, LINKEDIN_LINK } from '../consts';
const today = new Date();
---

<footer class="border-t bg-muted/30 py-12 md:py-16">
	<div class="container mx-auto px-4">
		<div class="grid grid-cols-1 md:grid-cols-4 gap-8 text-right">
			<div class="space-y-4">
				<h3 class="text-xl font-bold font-cairo text-gradient">{SITE_TITLE}</h3>
				<p class="text-sm text-muted-foreground leading-relaxed">
					تمكين الطلاب من خلال خدمات تعليمية متميزة وتجارب تعلم تفاعلية تلبي احتياجاتهم.
				</p>
			</div>
			
			<div>
				<h4 class="font-bold font-cairo mb-4 text-sm uppercase tracking-wider">المصادر</h4>
				<ul class="space-y-2 text-sm">
					<li><a href="/blog" class="text-muted-foreground hover:text-primary transition-colors">جميع الكورسات</a></li>
					<li><a href="/about" class="text-muted-foreground hover:text-primary transition-colors">أدلة الدراسة</a></li>
					<li><a href="#" class="text-muted-foreground hover:text-primary transition-colors">المجتمع الطلابي</a></li>
				</ul>
			</div>
			
			<div>
				<h4 class="font-bold font-cairo mb-4 text-sm uppercase tracking-wider">الشركة</h4>
				<ul class="space-y-2 text-sm">
					<li><a href="/about" class="text-muted-foreground hover:text-primary transition-colors">من نحن</a></li>
					<li><a href="#" class="text-muted-foreground hover:text-primary transition-colors">سياسة الخصوصية</a></li>
					<li><a href="#" class="text-muted-foreground hover:text-primary transition-colors">شروط الخدمة</a></li>
				</ul>
			</div>
			
			<div>
				<h4 class="font-bold font-cairo mb-4 text-sm uppercase tracking-wider">تواصل معنا</h4>
				<div class="flex gap-4">
					<a href={TWITTER_LINK} class="text-muted-foreground hover:text-primary transition-colors" target="_blank">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path></svg>
					</a>
					<a href={INSTAGRAM_LINK} class="text-muted-foreground hover:text-primary transition-colors" target="_blank">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>
					</a>
					<a href={LINKEDIN_LINK} class="text-muted-foreground hover:text-primary transition-colors" target="_blank">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle></svg>
					</a>
				</div>
			</div>
		</div>
		
		<div class="mt-12 pt-8 border-t text-center text-sm text-muted-foreground">
			&copy; {today.getFullYear()} {SITE_TITLE}. جميع الحقوق محفوظة.
		</div>
	</div>
</footer>
