---
const stats = [
	{ label: "طالب نشط", value: "+10,000", icon: "👨‍🎓" },
	{ label: "كورس متخصص", value: "+250", icon: "📚" },
	{ label: "نسبة النجاح", value: "98%", icon: "⭐" },
	{ label: "أداة تفاعلية", value: "+50", icon: "⚙️" },
];
---
<section class="py-12 border-y bg-muted/20">
	<div class="container mx-auto px-4">
		<div class="grid grid-cols-2 md:grid-cols-4 gap-8">
			{stats.map((stat) => (
				<div class="text-center space-y-2 group transition-transform hover:scale-105">
					<div class="text-3xl mb-2">{stat.icon}</div>
					<div class="text-3xl md:text-4xl font-bold font-cairo text-foreground">{stat.value}</div>
					<div class="text-sm text-muted-foreground font-bold tracking-wider">{stat.label}</div>
				</div>
			))}
		</div>
	</div>
</section>
